# Solana Fair Value Oracle — Phase 0 credentials
# Copy to .env (gitignored) and fill in. All four Phase 0 validations run free.

# Helius (free tier, dashboard.helius.dev)
# 1M credits/mo, 10 RPC/s, 2 DAS/s. Used by V4 (DEX swaps) + V1 (Chainlink reconstruction).
HELIUS_API_KEY=

# Optional backup public Solana RPC (no key, rate-limited)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# RPC Fast (rpcfast.com) — Start tier free, 15 req/s, 1.5M CU/mo.
# Standard JSON-RPC; blocks getProgramAccounts / getTokenAccountsByOwner / ByDelegate
# / getTokenLargestAccounts on Start. Key passed via ?api_key= query string.
RPCFAST_API_KEY=
RPCFAST_RPC_URL=https://solana-rpc.rpcfast.com
RPCFAST_WS_URL=wss://solana-rpc.rpcfast.com

# Which provider handles standard Solana JSON-RPC by default: "helius" or "rpcfast".
# Per-call override available via provider= kwarg on sources.helius functions.
# Enhanced Transactions API is always Helius regardless of this.
PRIMARY_RPC=helius

# Deferred to Phase 1 MVP — Phase 0 does NOT require these.
# POLYGON_API_KEY=
# DATABENTO_API_KEY=
# EODHD_API_KEY=
