# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.ipynb_checkpoints/

# Rust
target/

# Env
.env
.env.local

# Data — gitignored because cached pulls may exceed repo size and may
# carry provider ToS constraints. Keep .gitkeep so dirs exist.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Reports output artifacts (images/csv) — keep the markdown writeups in-repo
reports/figures/
reports/tables/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Excel lock/temp files
~$*

# Claude Code — keep shared settings.json, ignore per-user local overrides
.claude/settings.local.json
