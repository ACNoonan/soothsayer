# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.ipynb_checkpoints/

# Rust
target/

# Node / Anchor TS — node_modules is huge; keep package-lock.json in-repo for
# deterministic CI installs.
node_modules/

# Env
.env
.env.local

# Data — gitignored because cached pulls may exceed repo size and may
# carry provider ToS constraints. Keep .gitkeep so dirs exist.
data/raw/*
data/processed/*
data/bot_tape/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/bot_tape/.gitkeep

# Reports output artifacts (images/csv) — keep the markdown writeups in-repo
reports/figures/
reports/tables/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Excel lock/temp files
~$*

# Claude Code — ignore the whole local agent directory (settings, per-user
# overrides, per-machine runtime state, harness ephemera).
.claude/

# Local-only working docs (outreach targets, draft messages, private notes)
*.local.md

# Personal research-networking scratch (arXiv endorsement candidate list,
# scraped emails, PDFs). Lives in repo for convenience; never committed.
arxiv-endorsement/
.vercel

# Third-party reference papers (copyright — kept locally, not redistributed)
research/coverage-inversion/exemplars/

# Internal working docs / editorial scaffolding — kept locally, not public
internal/
